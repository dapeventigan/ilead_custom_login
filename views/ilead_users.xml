<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ilead_users_action" model="ir.actions.act_window">
        <field name="name">Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p>Add a User</p>
        </field>
    </record>
    <record id="ilead_users_view_list" model="ir.ui.view">
        <field name="name">ilead_users.view.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="">
                <header>
                    <button name="activate_user" type="object" string="Activate User" class="btn-primary"/>
                </header>
                <field name="name" />
                <field name="login" />
                <field name="email" />
            </list>
        </field>
    </record>
    <record id="ilead_users_view_form" model="ir.ui.view">
        <field name="name">ilead_users.view.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <field name="login" />
                        <field name="email" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>