<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="ilead_custom_reset_password" name="iLead Custom Reset Password">
        <t t-name="ilead_custom_reset_password">
            <t t-set="title">Reset Password</t>
            <t t-call-assets="web.assets_frontend" t-js="false"/>
            <t t-call-assets="web.assets_frontend" t-css="false"/>
            <div class="login-bg">
                <div class="login-card">
                    <div class="login-header">
                        <img src="/custom_login/static/src/img/icon.png" class="login-logo" alt="Logo"/>
                    </div>
                    <div t-if="message" class="login-form">
                        <p class="alert alert-success" role="status">
                            <t t-esc="message"/>
                        </p>
                        <div class="login-footer">
                            <a href="/web/login">Back to Login</a>
                        </div>
                    </div>
                    <form class="login-form" role="form" method="post" t-if="not message" data-captcha="password_reset">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="token" t-att-value="token"/>
                        <t t-if="token and not invalid_token">
                            <div class="input-group mb-3">
                                <span class="input-icon">
                                    <i class="fa fa-lock"></i>
                                </span>
                                <input type="password" name="password" id="password" 
                                       class="login-input" required="required" 
                                       autocomplete="new-password" placeholder="New Password" autofocus="autofocus"/>
                            </div>
                            <div class="input-group">
                                <span class="input-icon">
                                    <i class="fa fa-check-circle"></i>
                                </span>
                                <input type="password" name="confirm_password" id="confirm_password" 
                                       class="login-input" required="required" 
                                       autocomplete="new-password" placeholder="Confirm Password"/>
                            </div>
                        </t>
                        <t t-if="not token">
                            <div class="input-group">
                                <span class="input-icon">
                                    <i class="fa fa-envelope"></i>
                                </span>
                                <input type="text" name="login" t-att-value="login" id="login" 
                                       class="login-input" required="required" 
                                       placeholder="Email Address" autofocus="autofocus"/>
                            </div>
                        </t>
                        <p class="login-error" t-if="error" style="color: #ff4d4d; margin-top: 10px;">
                            <t t-esc="error"/>
                        </p>
                        <button type="submit" class="login-btn mt-3">Confirm</button>
                        <div class="login-footer mt-3">
                            <a href="/web/login">Back to Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>