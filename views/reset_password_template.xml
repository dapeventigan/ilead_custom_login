<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="password_renew_template" name="Password Renewal Page">
        <t>
            <t t-set="title">Reset Password</t>
            <t t-call-assets="web.assets_frontend" t-js="false"/>
            <t t-call-assets="web.assets_frontend" t-css="false"/>
            <div class="login-bg">
                <div class="login-card">
                    <div class="login-header">
                        <img src="/custom_login/static/src/img/icon.png" class="login-logo" alt="Logo"/>
                    </div>
                    <form class="login-form" role="form" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <h3 class="text-center" style="color: #333; margin-bottom: 5px;">Password Renewal</h3>
                        <p class="text-center text-muted small" style="margin-bottom: 20px;">
                            Your password has expired. Please update it to continue.
                        </p>
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fa fa-user"></i>
                            </span>
                            <input type="text" name="login" placeholder="Username" required="required" class="login-input"/>
                        </div>
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fa fa-unlock-alt"></i>
                            </span>
                            <input type="password" name="old_password" placeholder="Current Password" required="required" class="login-input"/>
                        </div>
                        <hr style="border-top: 1px solid #eee; margin: 20px 0;"/>
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fa fa-lock"></i>
                            </span>
                            <input type="password" name="new_password" placeholder="New Password" required="required" class="login-input"/>
                        </div>
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fa fa-check-circle"></i>
                            </span>
                            <input type="password" name="confirm_password" placeholder="Confirm New Password" required="required" class="login-input"/>
                        </div>
                        <button type="submit" class="login-btn">Update &amp; Login</button>
                        <t t-if="error">
                            <div class="login-error" style="color: #d9534f; margin-top: 15px; text-align: center; font-size: 14px;">
                                <i class="fa fa-exclamation-triangle"></i>
                                <t t-esc="error"/>
                            </div>
                        </t>
                        <div class="login-footer" style="margin-top: 20px;">
                            <a href="/web/login">Back to Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>